{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "vardaansharma.com"
        }
      ],
      "destination": "https://www.vardaansharma.com/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/:project/running",
      "destination": "/:project/running/index.html"
    },
    {
      "source": "/:project/running/",
      "destination": "/:project/running/index.html"
    },
    {
      "source": "/api/(.*)",
      "destination": "https://vardaansharma100-portfolio.hf.space/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ]
}